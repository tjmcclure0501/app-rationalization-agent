{
  "_comment": "Scoring rubric for the 5-R app rationalization framework. Weights must sum to 1.0 per category group.",

  "category_weights": {
    "activity":     0.30,
    "health":       0.30,
    "quality":      0.20,
    "complexity":   0.20
  },

  "thresholds": {
    "retain":   { "min_score": 0.75, "min_confidence": 0.70 },
    "rehost":   { "min_score": 0.55, "min_confidence": 0.60 },
    "refactor": { "min_score": 0.35, "min_confidence": 0.55 },
    "rewrite":  { "min_score": 0.15, "min_confidence": 0.50 },
    "retire":   { "min_score": 0.00, "min_confidence": 0.40 }
  },

  "confidence": {
    "flag_for_review_below": 0.55,
    "low_signal_penalty": 0.15
  },

  "activity_signals": {
    "last_commit_days": {
      "weight": 0.40,
      "score_map": {
        "0-30":    1.0,
        "31-90":   0.8,
        "91-180":  0.6,
        "181-365": 0.4,
        "366-730": 0.2,
        "730+":    0.0
      }
    },
    "commit_frequency_per_month": {
      "weight": 0.35,
      "score_map": {
        "20+":  1.0,
        "10-19": 0.8,
        "5-9":  0.6,
        "2-4":  0.4,
        "1":    0.2,
        "0":    0.0
      }
    },
    "contributor_count": {
      "weight": 0.25,
      "score_map": {
        "20+": 1.0,
        "10-19": 0.8,
        "5-9":  0.6,
        "2-4":  0.4,
        "1":    0.2
      }
    }
  },

  "health_signals": {
    "runtime_eol": {
      "weight": 0.35,
      "description": "Is the primary runtime/language version EOL?",
      "score_map": {
        "current":    1.0,
        "lts":        0.8,
        "maintenance": 0.5,
        "eol":        0.0
      }
    },
    "dependency_freshness": {
      "weight": 0.35,
      "description": "Ratio of up-to-date dependencies",
      "score_map": {
        "0.9-1.0":  1.0,
        "0.7-0.89": 0.7,
        "0.5-0.69": 0.4,
        "0.0-0.49": 0.1
      }
    },
    "open_issues_ratio": {
      "weight": 0.30,
      "description": "open_issues / total_issues — lower is healthier",
      "score_map": {
        "0.0-0.2":  1.0,
        "0.21-0.4": 0.7,
        "0.41-0.6": 0.4,
        "0.61-1.0": 0.1
      }
    }
  },

  "quality_signals": {
    "has_tests": {
      "weight": 0.40,
      "description": "Presence of test files or test directories",
      "score_map": {
        "yes": 1.0,
        "partial": 0.5,
        "no": 0.0
      }
    },
    "has_readme": {
      "weight": 0.25,
      "score_map": {
        "detailed": 1.0,
        "basic": 0.5,
        "missing": 0.0
      }
    },
    "has_ci": {
      "weight": 0.20,
      "description": "GitHub Actions, CircleCI, or similar CI config present",
      "score_map": {
        "yes": 1.0,
        "no":  0.0
      }
    },
    "has_license": {
      "weight": 0.15,
      "score_map": {
        "yes": 1.0,
        "no":  0.0
      }
    }
  },

  "complexity_signals": {
    "lines_of_code": {
      "weight": 0.50,
      "description": "Total LOC — very low LOC may indicate skeleton/retired project",
      "score_map": {
        "1000-50000":  1.0,
        "50001-200000": 0.7,
        "200001+":     0.4,
        "0-999":       0.2
      }
    },
    "architecture_signals": {
      "weight": 0.50,
      "description": "Modular vs monolith proxies (multiple packages, clear separation)",
      "score_map": {
        "modular":  1.0,
        "mixed":    0.6,
        "monolith": 0.3
      }
    }
  },

  "recommendation_logic": {
    "_comment": "Final 5-R decision uses weighted score + contextual overrides",
    "overrides": {
      "force_retire_if": [
        "last_commit_days > 1095",
        "contributor_count == 1 AND last_commit_days > 365",
        "lines_of_code < 50"
      ],
      "force_rewrite_if": [
        "runtime_eol == true AND dependency_freshness < 0.3",
        "has_tests == false AND lines_of_code > 50000"
      ],
      "force_review_if": [
        "confidence < 0.55",
        "conflicting_signals_detected == true"
      ]
    }
  }
}
