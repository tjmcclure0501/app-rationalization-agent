# App Rationalization Agent — environment template
# Copy this file to `.env` and populate the values below. Never commit `.env`.

# GitHub personal access token (classic or fine-grained).
# Used for: /repos, /git/trees, /contents, /readme, /commits,
#           /stats/participation, /contributors, /issues
# Required scopes: public_repo (sufficient for public repos).
# Without a token you'll hit the 60 req/hr unauthenticated limit.
GITHUB_TOKEN=

# Anthropic API key — only needed if you extend an agent to call the
# Claude API directly. The current pipeline does not require it.
ANTHROPIC_API_KEY=
